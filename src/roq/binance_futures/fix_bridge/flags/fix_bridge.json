{
  "name": "roq/binance_futures/fix_bridge/flags/FIXBridge",
  "type": "flags",
  "prefix": "fix_bridge_",
  "values": [
    {
      "name": "comp_id",
      "type": "std/string",
      "default": "binance-futures",
      "description": "Server component identifier"
    },
    {
      "name": "auth_method",
      "type": "std/string",
      "description": "Authentication method: (empty), hmac_sha256, hmac_sha256_ts"
    },
    {
      "name": "auth_timestamp_tolerance",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Authentication timestamp tolerance"
    },
    {
      "name": "logon_timeout",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "description": "Logon timeout (heartbeat frequency is used if not specified)"
    },
    {
      "name": "logon_heartbeat_min",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Minimum accepted client heartbeat frequency"
    },
    {
      "name": "logon_heartbeat_max",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "60s",
      "description": "Maximum accepted client heartbeat frequency"
    },
    {
      "name": "heartbeat_freq",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Server to client heartbeat frequency"
    },
    {
      "name": "decode_buffer_size",
      "type": "std/uint32",
      "default": 1048576,
      "description": "Decode buffer size"
    },
    {
      "name": "debug",
      "type": "std/bool",
      "default": false,
      "description": "Log fix messages?"
    },
    {
      "name": "log_path",
      "type": "std/string",
      "description": "Filesystem path when logging fix messages"
    },
    {
      "name": "strict_checking",
      "type": "std/bool",
      "default": false,
      "description": "Hard failure on assertions"
    },
    {
      "name": "disable_req_id_validation",
      "type": "std/bool",
      "default": false,
      "description": "Disable req_id validation? (default is to require web base64 characters)"
    },
    {
      "name": "top_of_book_from_market_by_price",
      "type": "std/bool",
      "default": false,
      "description": "Use MarketByPrice instead of TopOfBook?"
    },
    {
      "name": "route_by_strategy",
      "type": "std/bool",
      "default": false,
      "description": "Route order updates using strategy_id?"
    },
    {
      "name": "test_exchange_time_as_sending_time",
      "type": "std/bool",
      "default": false,
      "description": "TEST Use exchange time for sending time (tag 52)?"
    },
    {
      "name": "test_cancel_on_disconnect",
      "type": "std/bool",
      "default": false,
      "description": "TEST Cancel orders on disconnect?"
    },
    {
      "name": "test_request_latency",
      "type": "std/bool",
      "default": false,
      "description": "TEST Log round-trip latencies?"
    }
  ]
}
