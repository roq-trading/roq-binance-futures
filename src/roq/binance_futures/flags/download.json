{
  "name": "Download",
  "type": "flags",
  "prefix": "download_",
  "values": [
    {
      "name": "symbols",
      "type": "std::vector<std::string>",
      "description": "Comma-separated list of symbols"
    },
    {
      "name": "trades_lookback",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "300s",
      "description": "Download trades lookback period"
    },
    {
      "name": "trades_lookback_on_restart",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "{}",
      "description": "Download trades lookback period"
    },
    {
      "name": "trades_limit",
      "type": "uint32_t",
      "default": 1000,
      "description": "Download trades limit"
    }
  ]
}
