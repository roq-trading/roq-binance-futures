{
  "name": "REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "https://testnet.binancefuture.com",
      "description": "REST end-point (URI)"
    },
    {
      "name": "host",
      "type": "std::string",
      "description": "Host (http header) in case uri uses an IP address"
    },
    {
      "name": "pm_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "description": "REST end-point for portfolio margin (URI)"
    },
    {
      "name": "pm_host",
      "type": "std::string",
      "description": "Host (http header) in case uri uses an IP address"
    },
    {
      "name": "proxy",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "description": "Proxy end-point (URI)"
    },
    {
      "name": "ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std::string",
      "validator": "roq::flags::validators::Path",
      "default": "/v1/time",
      "description": "URI path used for REST connection keep-alive messages (*without* the api prefix)"
    },
    {
      "name": "request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Request: timeout"
    },
    {
      "name": "terminate_on_403",
      "type": "bool",
      "default": false,
      "description": "Terminate when getting a 403 response code"
    },
    {
      "name": "back_off_delay",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "300s",
      "description": "Time to wait before retrying a rejected request"
    },
    {
      "name": "listen_key_refresh",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "1800s",
      "description": "Listen key refresh period"
    },
    {
      "name": "order_countdown",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "30s",
      "description": "Auto-cancel countdown time"
    },
    {
      "name": "order_recv_window",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::flags::validators::TimePeriod",
      "default": "5000ms",
      "description": "Receive window, please refer to Binance documentation!"
    },
    {
      "name": "cancel_on_disconnect",
      "type": "bool",
      "default": false,
      "description": "Cancel orders on disconnect? (bool)"
    }
  ]
}
